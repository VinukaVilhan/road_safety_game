<?xml version="1.0" encoding="utf-8"?>
<!-- Many internet radio streams still use HTTP; ExoPlayer needs cleartext allowed. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
